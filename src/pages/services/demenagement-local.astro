---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CTA from '../../components/CTA.astro';
import TablerIcon from '../../components/TablerIcon.astro';
import { client } from '../../data/client';

const zones = [
  'Montpellier', 'Castelnau-le-Lez', 'Lattes', 'Saint-Jean-de-Védas',
  'Béziers', 'Juvignac', 'Pérols', 'Palavas-les-Flots',
  'Lunel', 'Sète', 'Frontignan', 'Mauguio',
];
---

<BaseLayout
  title="Déménagement Local Montpellier et Alentours — AC Coursing"
  description="Déménagement local à Montpellier, Castelnau-le-Lez, Lattes, Béziers et alentours. Disponible 7j/7, réponse rapide, prix fixe garanti."
  schema={{
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'Déménagement local Montpellier',
    provider: { '@type': 'MovingCompany', name: client.name, telephone: client.phoneForTel, url: client.domain },
    areaServed: [
      { '@type': 'City', name: 'Montpellier' },
      { '@type': 'City', name: 'Castelnau-le-Lez' },
      { '@type': 'City', name: 'Lattes' },
      { '@type': 'City', name: 'Béziers' },
    ],
  }}
>
  <Header slot="header" />

  <section class="bg-primary py-14 sm:py-16">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <nav aria-label="Breadcrumb" class="mb-4">
        <ol class="flex items-center gap-1.5 text-sm text-primary-fg/60">
          <li><a href="/" class="hover:text-primary-fg transition-colors">Accueil</a></li>
          <li class="flex items-center gap-1.5"><TablerIcon name="chevron-right" class="size-3.5" /><a href="/services" class="hover:text-primary-fg transition-colors">Services</a></li>
          <li class="flex items-center gap-1.5"><TablerIcon name="chevron-right" class="size-3.5" /><span class="text-primary-fg" aria-current="page">Déménagement local</span></li>
        </ol>
      </nav>
      <h1 class="font-heading text-h1 font-bold uppercase text-primary-fg">Déménagement local</h1>
      <p class="mt-3 max-w-xl text-primary-fg/80">Montpellier et tout le département 34. Disponible 7j/7.</p>
    </div>
  </section>

  <section class="bg-background py-section">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:gap-16 items-start">
        <div class="space-y-6">
          <p class="text-lg leading-relaxed text-muted-foreground">
            Un déménagement local, même court, mérite la même rigueur qu'un long trajet. On intervient vite, on emballe soigneusement et on remet en place dans le nouveau logement.
          </p>
          <p class="leading-relaxed text-muted-foreground">
            Disponible du lundi au dimanche, on s'adapte à vos dates, même en dernière minute si le planning le permet.
          </p>

          <ul class="space-y-4">
            {[
              { icon: 'map-pin', text: 'Intervention rapide dans tout le 34' },
              { icon: 'clock', text: 'Disponible 7j/7, créneaux tôt le matin ou en soirée' },
              { icon: 'truck-delivery', text: 'Camions de différentes tailles selon le volume' },
              { icon: 'shield-check', text: 'Assurance transport incluse, prix fixe garanti' },
            ].map(({ icon, text }) => (
              <li class="flex items-start gap-3">
                <span class="flex size-9 shrink-0 items-center justify-center rounded-lg bg-primary/10 text-primary mt-0.5">
                  <TablerIcon name={icon} class="text-lg leading-none" />
                </span>
                <span class="text-muted-foreground leading-relaxed">{text}</span>
              </li>
            ))}
          </ul>

          <a href="/devis" class="inline-flex min-h-[50px] items-center gap-2 rounded-full bg-primary px-8 py-3 text-base font-bold text-primary-foreground shadow-md transition-all hover:opacity-90">
            Estimer le coût
            <TablerIcon name="arrow-right" class="text-base leading-none" />
          </a>
        </div>

        <div class="space-y-6">
          <img
            src="/images/residentiel/residentiel-05.webp"
            alt="Déménagement local à Montpellier — camion AC Coursing dans le quartier"
            loading="lazy"
            decoding="async"
            class="w-full rounded-2xl border border-border object-cover aspect-[4/3]"
          />

          <div class="rounded-2xl border border-border bg-card p-5">
            <p class="text-sm font-semibold text-primary mb-3">Zones desservies</p>
            <div class="flex flex-wrap gap-2">
              {zones.map((zone) => (
                <span class="rounded-full border border-border bg-background px-3 py-1 text-sm text-muted-foreground">{zone}</span>
              ))}
            </div>
            <p class="mt-3 text-xs text-muted-foreground">Votre ville n'est pas listée ? <a href="/contact" class="text-primary underline underline-offset-2">Contactez-nous</a>, on intervient dans tout l'Hérault.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTA />
  <Footer slot="footer" />
</BaseLayout>
