---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CTA from '../../components/CTA.astro';
import TablerIcon from '../../components/TablerIcon.astro';
import { client } from '../../data/client';
---

<BaseLayout
  title="Déménagement avec Mise en Carton à Montpellier — AC Coursing"
  description="Emballage complet de vos affaires par notre équipe à Montpellier. Cartons renforcés, papier bulle, protection des objets fragiles. Devis gratuit."
  schema={{
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'Déménagement avec mise en carton',
    provider: { '@type': 'MovingCompany', name: client.name, telephone: client.phoneForTel, url: client.domain },
    areaServed: { '@type': 'City', name: 'Montpellier' },
  }}
>
  <Header slot="header" />

  <section class="bg-primary py-14 sm:py-16">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <nav aria-label="Breadcrumb" class="mb-4">
        <ol class="flex items-center gap-1.5 text-sm text-primary-fg/60">
          <li><a href="/" class="hover:text-primary-fg transition-colors">Accueil</a></li>
          <li class="flex items-center gap-1.5"><TablerIcon name="chevron-right" class="size-3.5" /><a href="/services" class="hover:text-primary-fg transition-colors">Services</a></li>
          <li class="flex items-center gap-1.5"><TablerIcon name="chevron-right" class="size-3.5" /><span class="text-primary-fg" aria-current="page">Mise en carton</span></li>
        </ol>
      </nav>
      <h1 class="font-heading text-h1 font-bold uppercase text-primary-fg">Déménagement avec mise en carton</h1>
      <p class="mt-3 max-w-xl text-primary-fg/80">On emballe tout avant le jour J. Vous n'avez plus qu'à partir.</p>
    </div>
  </section>

  <section class="bg-background py-section">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:gap-16 items-center">
        <div class="space-y-6">
          <p class="text-lg leading-relaxed text-muted-foreground">
            L'emballage, c'est souvent la partie la plus longue d'un déménagement. On s'en charge avec du matériel professionnel : cartons double cannelure, papier bulle, couvertures de protection, housses pour les meubles.
          </p>
          <p class="leading-relaxed text-muted-foreground">
            Chaque objet est emballé selon sa fragilité. La vaisselle, les livres, les vêtements, l'électronique — tout est trié, étiqueté et chargé dans l'ordre pour que le déballage soit rapide de l'autre côté.
          </p>
          <ul class="space-y-4">
            {[
              { icon: 'box', text: 'Cartons renforcés fournis — double cannelure pour les objets lourds' },
              { icon: 'package', text: 'Papier bulle et housses pour les objets fragiles et le mobilier' },
              { icon: 'check', text: 'Étiquetage par pièce pour faciliter le déballage' },
              { icon: 'shield-check', text: 'Assurance transport incluse sur tous les objets emballés' },
              { icon: 'trash', text: 'Récupération des cartons après déménagement sur demande' },
            ].map(({ icon, text }) => (
              <li class="flex items-start gap-3">
                <span class="flex size-9 shrink-0 items-center justify-center rounded-lg bg-primary/10 text-primary mt-0.5">
                  <TablerIcon name={icon} class="text-lg leading-none" />
                </span>
                <span class="text-muted-foreground leading-relaxed">{text}</span>
              </li>
            ))}
          </ul>
          <a href="/devis" class="inline-flex min-h-[50px] items-center gap-2 rounded-full bg-primary px-8 py-3 text-base font-bold text-primary-foreground shadow-md transition-all hover:opacity-90">
            Demander un devis
            <TablerIcon name="arrow-right" class="text-base leading-none" />
          </a>
        </div>
        <div>
          <img
            src="/images/residentiel/residentiel-03.webp"
            alt="Emballage professionnel de mobilier avec cartons renforcés — AC Coursing Montpellier"
            loading="lazy"
            decoding="async"
            class="w-full rounded-2xl border border-border object-cover aspect-[4/3]"
          />
        </div>
      </div>
    </div>
  </section>

  <CTA />
  <Footer slot="footer" />
</BaseLayout>
