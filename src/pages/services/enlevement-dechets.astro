---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CTA from '../../components/CTA.astro';
import TablerIcon from '../../components/TablerIcon.astro';
import { client } from '../../data/client';
---

<BaseLayout
  title="Enlèvement de Déchets et Débarras lors d'un Déménagement — AC Coursing"
  description="Évacuation d'encombrants, débarras de mobilier et collecte de déchets lors de votre déménagement à Montpellier. Traitement responsable, prix fixe."
  schema={{
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'Enlèvement de déchets liés à un déménagement',
    provider: { '@type': 'MovingCompany', name: client.name, telephone: client.phoneForTel, url: client.domain },
    areaServed: { '@type': 'City', name: 'Montpellier' },
  }}
>
  <Header slot="header" />

  <section class="bg-primary py-14 sm:py-16">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <nav aria-label="Breadcrumb" class="mb-4">
        <ol class="flex items-center gap-1.5 text-sm text-primary-fg/60">
          <li><a href="/" class="hover:text-primary-fg transition-colors">Accueil</a></li>
          <li class="flex items-center gap-1.5"><TablerIcon name="chevron-right" class="size-3.5" /><a href="/services" class="hover:text-primary-fg transition-colors">Services</a></li>
          <li class="flex items-center gap-1.5"><TablerIcon name="chevron-right" class="size-3.5" /><span class="text-primary-fg" aria-current="page">Enlèvement de déchets</span></li>
        </ol>
      </nav>
      <h1 class="font-heading text-h1 font-bold uppercase text-primary-fg">Enlèvement de déchets</h1>
      <p class="mt-3 max-w-xl text-primary-fg/80">Ce que vous ne voulez plus, on l'évacue. Proprement.</p>
    </div>
  </section>

  <section class="bg-background py-section">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:gap-16 items-center">
        <div>
          <img
            src="/images/residentiel/residentiel-02.webp"
            alt="Évacuation d'encombrants et débarras lors d'un déménagement à Montpellier — AC Coursing"
            loading="lazy"
            decoding="async"
            class="w-full rounded-2xl border border-border object-cover aspect-[4/3]"
          />
        </div>

        <div class="space-y-6">
          <p class="text-lg leading-relaxed text-muted-foreground">
            Un déménagement, c'est aussi l'occasion de faire le tri. Meubles à jeter, cartons usagés, électroménager hors service — on s'en charge directement, le même jour si possible.
          </p>
          <p class="leading-relaxed text-muted-foreground">
            Les objets récupérables sont orientés vers des filières de réemploi ou de recyclage. Rien ne finit en décharge sans raison.
          </p>

          <ul class="space-y-4">
            {[
              { icon: 'trash', text: 'Évacuation de mobilier, électroménager et encombrants' },
              { icon: 'box', text: 'Récupération des cartons après déménagement' },
              { icon: 'check', text: 'Tri et orientation vers le recyclage ou le réemploi' },
              { icon: 'truck-delivery', text: 'Chargement et transport inclus dans la prestation' },
              { icon: 'clock', text: 'Intervention le jour du déménagement ou à part' },
            ].map(({ icon, text }) => (
              <li class="flex items-start gap-3">
                <span class="flex size-9 shrink-0 items-center justify-center rounded-lg bg-primary/10 text-primary mt-0.5">
                  <TablerIcon name={icon} class="text-lg leading-none" />
                </span>
                <span class="text-muted-foreground leading-relaxed">{text}</span>
              </li>
            ))}
          </ul>

          <a href="/devis" class="inline-flex min-h-[50px] items-center gap-2 rounded-full bg-primary px-8 py-3 text-base font-bold text-primary-foreground shadow-md transition-all hover:opacity-90">
            Demander un devis
            <TablerIcon name="arrow-right" class="text-base leading-none" />
          </a>
        </div>
      </div>
    </div>
  </section>

  <CTA />
  <Footer slot="footer" />
</BaseLayout>
