---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CTA from '../../components/CTA.astro';
import TablerIcon from '../../components/TablerIcon.astro';
import { client } from '../../data/client';
---

<BaseLayout
  title="Déménagement pour Seniors à Montpellier — AC Coursing"
  description="Service de déménagement attentionné pour les personnes âgées à Montpellier. Accompagnement complet, patience et soin à chaque étape. Devis gratuit."
  schema={{
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'Déménagement pour seniors',
    provider: { '@type': 'MovingCompany', name: client.name, telephone: client.phoneForTel, url: client.domain },
    areaServed: { '@type': 'City', name: 'Montpellier' },
    description: 'Service de déménagement spécialisé pour les personnes âgées à Montpellier.',
  }}
>
  <Header slot="header" />

  <section class="bg-primary py-14 sm:py-16">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <nav aria-label="Breadcrumb" class="mb-4">
        <ol class="flex items-center gap-1.5 text-sm text-primary-fg/60">
          <li><a href="/" class="hover:text-primary-fg transition-colors">Accueil</a></li>
          <li class="flex items-center gap-1.5"><TablerIcon name="chevron-right" class="size-3.5" /><a href="/services" class="hover:text-primary-fg transition-colors">Services</a></li>
          <li class="flex items-center gap-1.5"><TablerIcon name="chevron-right" class="size-3.5" /><span class="text-primary-fg" aria-current="page">Seniors</span></li>
        </ol>
      </nav>
      <h1 class="font-heading text-h1 font-bold uppercase text-primary-fg">Déménagement pour seniors</h1>
      <p class="mt-3 max-w-xl text-primary-fg/80">Un accompagnement complet, à votre rythme, sans stress.</p>
    </div>
  </section>

  <section class="bg-background py-section">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:gap-16 items-center">

        <div class="space-y-6">
          <p class="text-lg leading-relaxed text-muted-foreground">
            Déménager à un certain âge demande plus que des bras solides. Ça demande de la patience, de l'écoute et une organisation qui ménage vos habitudes. Notre équipe est formée à ça.
          </p>
          <p class="leading-relaxed text-muted-foreground">
            Du tri au placement des meubles dans le nouveau logement, on prend le temps de faire les choses bien. Vous n'avez pas à gérer les détails — on s'en occupe.
          </p>

          <ul class="space-y-4">
            {[
              { icon: 'heart', text: 'Équipe attentionnée, habitée à travailler avec des personnes âgées' },
              { icon: 'clock', text: 'Rythme adapté — pas de précipitation' },
              { icon: 'box', text: 'Emballage complet inclus sur demande' },
              { icon: 'home', text: 'Remise en place des meubles dans le nouvel appartement' },
              { icon: 'phone', text: 'Un numéro direct pour joindre l\'équipe avant et après le jour J' },
            ].map(({ icon, text }) => (
              <li class="flex items-start gap-3">
                <span class="flex size-9 shrink-0 items-center justify-center rounded-lg bg-primary/10 text-primary mt-0.5">
                  <TablerIcon name={icon} class="text-lg leading-none" />
                </span>
                <span class="text-muted-foreground leading-relaxed">{text}</span>
              </li>
            ))}
          </ul>

          <a
            href="/devis"
            class="inline-flex min-h-[50px] items-center gap-2 rounded-full bg-primary px-8 py-3 text-base font-bold text-primary-foreground shadow-md transition-all hover:opacity-90"
          >
            Demander un devis
            <TablerIcon name="arrow-right" class="text-base leading-none" />
          </a>
        </div>

        <div>
          <img
            src="/images/residentiel/residentiel-02.webp"
            alt="Déménagement soigné pour senior à Montpellier — équipe AC Coursing"
            loading="lazy"
            decoding="async"
            class="w-full rounded-2xl border border-border object-cover aspect-[4/3]"
          />
        </div>
      </div>

      <div class="mt-16 rounded-2xl border border-border bg-card p-8" data-reveal>
        <h2 class="font-heading text-h3 font-bold uppercase text-primary">Ce que comprend le service</h2>
        <div class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2">
          {[
            'Visite préalable ou entretien téléphonique pour évaluer le volume',
            'Démontage et remontage de tous les meubles',
            'Emballage des objets fragiles et de la vaisselle',
            'Transport sécurisé avec assurance incluse',
            'Installation dans le nouveau logement selon vos indications',
            'Évacuation des cartons et emballages après déménagement',
          ].map((item) => (
            <div class="flex items-start gap-3">
              <TablerIcon name="check" class="mt-0.5 shrink-0 text-xl leading-none text-primary" />
              <span class="text-sm text-muted-foreground leading-relaxed">{item}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <CTA />
  <Footer slot="footer" />
</BaseLayout>
