---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CTA from '../../components/CTA.astro';
import TablerIcon from '../../components/TablerIcon.astro';
import { client } from '../../data/client';
import { getPlacesData, formatRating } from '../../lib/google-places';

const places = await getPlacesData();
const ratingDisplay = formatRating(places.rating);
---

<BaseLayout
  title="Déménagement Longue Distance — AC Coursing Montpellier"
  description="Déménagement longue distance depuis Montpellier vers toutes les villes de France. Transport direct, prix fixe garanti, livraison dans les délais."
  schema={{
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'Déménagement longue distance',
    provider: { '@type': 'MovingCompany', name: client.name, telephone: client.phoneForTel, url: client.domain },
    areaServed: { '@type': 'Country', name: 'France' },
    description: 'Déménagement longue distance depuis Montpellier vers toutes les villes de France.',
  }}
>
  <Header slot="header" />

  <section class="bg-primary py-14 sm:py-16">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <nav aria-label="Breadcrumb" class="mb-4">
        <ol class="flex items-center gap-1.5 text-sm text-primary-fg/60">
          <li><a href="/" class="hover:text-primary-fg transition-colors">Accueil</a></li>
          <li class="flex items-center gap-1.5"><TablerIcon name="chevron-right" class="size-3.5" /><a href="/services" class="hover:text-primary-fg transition-colors">Services</a></li>
          <li class="flex items-center gap-1.5"><TablerIcon name="chevron-right" class="size-3.5" /><span class="text-primary-fg" aria-current="page">Longue distance</span></li>
        </ol>
      </nav>
      <h1 class="font-heading text-h1 font-bold uppercase text-primary-fg">Déménagement longue distance</h1>
      <p class="mt-3 max-w-xl text-primary-fg/80">Depuis Montpellier, partout en France. On gère le trajet, vous gérez votre arrivée.</p>
    </div>
  </section>

  <section class="bg-background py-section">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:gap-16 items-center">

        <div>
          <img
            src="/images/longue-distance/longue-distance-01.webp"
            alt="Camion AC Coursing prêt pour un déménagement longue distance depuis Montpellier"
            loading="lazy"
            decoding="async"
            class="w-full rounded-2xl border border-border object-cover aspect-[4/3]"
          />
        </div>

        <div class="space-y-6">
          <p class="text-lg leading-relaxed text-muted-foreground">
            Un déménagement longue distance, c'est surtout une question d'organisation. On cadre tout à l'avance : itinéraire, créneaux, matériel de protection. Vous avez un interlocuteur unique du départ à la livraison.
          </p>

          <ul class="space-y-4">
            {[
              { icon: 'map-pin', text: 'Départ depuis Montpellier et tout le département 34' },
              { icon: 'truck-delivery', text: 'Transport direct — pas de transit, pas de rupture de charge' },
              { icon: 'shield-check', text: 'Assurance transport incluse sur chaque prestation' },
              { icon: 'calendar', text: 'Créneau confirmé à l\'avance, respect des délais' },
              { icon: 'box', text: 'Emballage professionnel disponible pour les objets fragiles' },
            ].map(({ icon, text }) => (
              <li class="flex items-start gap-3">
                <span class="flex size-9 shrink-0 items-center justify-center rounded-lg bg-primary/10 text-primary mt-0.5">
                  <TablerIcon name={icon} class="text-lg leading-none" />
                </span>
                <span class="text-muted-foreground leading-relaxed">{text}</span>
              </li>
            ))}
          </ul>

          <a
            href="/devis"
            class="inline-flex min-h-12 items-center gap-2 rounded-full bg-primary px-8 py-3 text-base font-bold text-primary-foreground shadow-md transition-all hover:opacity-90"
          >
            Estimer le coût
            <TablerIcon name="arrow-right" class="text-base leading-none" />
          </a>
        </div>
      </div>

      <div class="mt-16 grid grid-cols-1 gap-6 border-t border-border pt-12 sm:grid-cols-3">
        {[
          { value: '1 500+', label: 'déménagements réalisés' },
          { value: `${ratingDisplay}/5`, label: 'note Google' },
          { value: '24h', label: 'réponse garantie' },
        ].map(({ value, label }) => (
          <div class="text-center" data-reveal>
            <p class="font-heading text-4xl font-bold text-primary">{value}</p>
            <p class="mt-1 text-sm text-muted-foreground">{label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTA />
  <Footer slot="footer" />
</BaseLayout>
