---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TablerIcon from '../../components/TablerIcon.astro';
import { client } from '../../data/client';
import { formatFrenchDate } from '../../lib/form-utils';

const fromCity = Astro.url.searchParams.get('from')?.trim() ?? '';
const toCity = Astro.url.searchParams.get('to')?.trim() ?? '';
const name = Astro.url.searchParams.get('name')?.trim() ?? '';
const moveDate = Astro.url.searchParams.get('date')?.trim() ?? '';

const rows: Array<{ icon: string; label: string; value: string }> = [];

if (fromCity && toCity) {
  rows.push({ icon: 'map-pin', label: 'Trajet', value: `${fromCity} → ${toCity}` });
}

if (moveDate) {
  rows.push({ icon: 'calendar', label: 'Date souhaitée', value: formatFrenchDate(moveDate) });
}

if (name) {
  rows.push({ icon: 'user', label: 'Nom', value: name });
}
---

<BaseLayout
  title="Demande reçue — AC Coursing"
  description="Votre demande de devis a bien été reçue. Notre équipe vous recontacte dans les 24h."
>
  <main class="min-h-[calc(100dvh-4rem)] bg-background flex items-center justify-center px-4 py-12">
    <div class="w-full max-w-lg">

      <!-- Card -->
      <div class="rounded-2xl border border-border bg-card p-6 shadow-sm sm:p-8 text-center">

        <!-- Check circle -->
        <div class="mx-auto mb-6 flex size-20 items-center justify-center rounded-full bg-green-500 text-white shadow-lg shadow-green-500/30">
          <TablerIcon name="check" class="text-4xl leading-none" />
        </div>

        <h1 class="font-heading text-2xl font-bold text-foreground sm:text-3xl">Demande reçue !</h1>
        <p class="mt-3 text-base leading-relaxed text-muted-foreground">
          Merci pour votre confiance. Notre équipe va étudier votre dossier
          et vous recontacter <strong class="font-semibold text-foreground">dans les 24h</strong> avec une estimation personnalisée.
        </p>

        {rows.length > 0 && (
          <div class="mt-6 rounded-xl border border-border bg-muted/30 px-4 pt-2.5 text-left">
            {rows.map((row) => (
              <div class="flex items-start gap-3 border-b border-border py-3 last:border-0">
                <span class="mt-0.5 flex size-7 shrink-0 items-center justify-center rounded-lg bg-primary/10 text-primary">
                  <TablerIcon name={row.icon} class="text-sm leading-none" />
                </span>
                <div class="min-w-0 flex-1">
                  <p class="text-xs font-semibold uppercase tracking-widest text-muted-foreground">{row.label}</p>
                  <p class="mt-0.5 text-[0.9rem] font-semibold text-foreground">{row.value}</p>
                </div>
              </div>
            ))}
          </div>
        )}

        <div class="my-6 h-px bg-border"></div>

        <!-- Info rows -->
        <div class="space-y-4 text-left">

          <div class="flex items-start gap-3">
            <span class="mt-0.5 flex size-9 shrink-0 items-center justify-center rounded-lg bg-primary/10 text-primary">
              <TablerIcon name="phone" class="text-base leading-none" />
            </span>
            <div>
              <p class="text-xs font-semibold uppercase tracking-widest text-muted-foreground">Besoin urgent ?</p>
              <a href={`tel:${client.phoneForTel}`} class="mt-0.5 block text-[0.95rem] font-semibold text-foreground underline-offset-2 hover:underline">
                {client.phoneFormatted}
              </a>
            </div>
          </div>

          <div class="flex items-start gap-3">
            <span class="mt-0.5 flex size-9 shrink-0 items-center justify-center rounded-lg bg-primary/10 text-primary">
              <TablerIcon name="clock" class="text-base leading-none" />
            </span>
            <div>
              <p class="text-xs font-semibold uppercase tracking-widest text-muted-foreground">Délai de réponse</p>
              <p class="mt-0.5 text-[0.95rem] font-semibold text-foreground">Sous 24h, du lundi au samedi</p>
            </div>
          </div>

          <div class="flex items-start gap-3">
            <span class="mt-0.5 flex size-9 shrink-0 items-center justify-center rounded-lg bg-primary/10 text-primary">
              <TablerIcon name="shield-check" class="text-base leading-none" />
            </span>
            <div>
              <p class="text-xs font-semibold uppercase tracking-widest text-muted-foreground">Ce que vous allez recevoir</p>
              <p class="mt-0.5 text-[0.95rem] font-semibold text-foreground">Devis gratuit · Prix fixe garanti · Sans engagement</p>
            </div>
          </div>

        </div>

        <div class="my-6 h-px bg-border"></div>

        <a
          href="/"
          class="inline-flex items-center gap-2 rounded-full bg-primary px-7 py-3 text-sm font-bold text-primary-foreground shadow-sm transition-opacity hover:opacity-90"
        >
          <TablerIcon name="arrow-left" class="text-sm leading-none" />
          Retour à l'accueil
        </a>
      </div>

    </div>
  </main>
</BaseLayout>
