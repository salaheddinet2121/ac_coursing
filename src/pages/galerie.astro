---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CTA from '../components/CTA.astro';
import TablerIcon from '../components/TablerIcon.astro';
import { getPlacesData, formatRating } from '../lib/google-places';

const places = await getPlacesData();
const ratingDisplay = formatRating(places.rating);

const categories = ['Tout', 'Résidentiel', 'Professionnel', 'Longue distance', 'Garde-meubles'];

const photos = [
  { src: '/images/residentiel/residentiel-01.webp',       alt: 'Déménagement appartement à Montpellier — chargement du mobilier par l\'équipe AC Coursing',   cat: 'Résidentiel' },
  { src: '/images/residentiel/residentiel-02.webp',       alt: 'Protection et emballage soigné de mobilier lors d\'un déménagement résidentiel à Montpellier', cat: 'Résidentiel' },
  { src: '/images/residentiel/residentiel-03.webp',       alt: 'Transport sécurisé d\'objets fragiles en camion pour un déménagement à Montpellier',           cat: 'Résidentiel' },
  { src: '/images/residentiel/residentiel-04.webp',       alt: 'Installation et remise en place du mobilier dans un appartement — AC Coursing Montpellier',    cat: 'Résidentiel' },
  { src: '/images/residentiel/residentiel-05.webp',       alt: 'Déménagement maison à Montpellier — équipe AC Coursing en action',                            cat: 'Résidentiel' },
  { src: '/images/professionnel/professionnel-01.webp',   alt: 'Déménagement de bureaux professionnels à Montpellier — AC Coursing',                          cat: 'Professionnel' },
  { src: '/images/professionnel/professionnel-02.webp',   alt: 'Emballage et protection de matériel professionnel lors d\'un transfert de locaux',             cat: 'Professionnel' },
  { src: '/images/longue-distance/longue-distance-01.webp', alt: 'Déménagement longue distance depuis Montpellier — camion prêt au départ AC Coursing',      cat: 'Longue distance' },
  { src: '/images/longue-distance/longue-distance-02.webp', alt: 'Livraison soignée lors d\'un déménagement longue distance partout en France',               cat: 'Longue distance' },
  { src: '/images/garde-meubles/garde-meubles-01.webp',   alt: 'Stockage sécurisé en garde-meubles à Montpellier — entrepôt AC Coursing',                    cat: 'Garde-meubles' },
  { src: '/images/garde-meubles/garde-meubles-02.webp',   alt: 'Garde-meubles organisé pour stockage temporaire de mobilier à Montpellier',                   cat: 'Garde-meubles' },
];

const stats = [
  { value: '1 500+', label: 'chantiers réalisés' },
  { value: String(places.reviewCount), label: 'avis 5★ Google' },
  { value: '11 ans', label: "d'expérience" },
  { value: `${ratingDisplay}/5`, label: 'note moyenne' },
];
---

<BaseLayout
  title="Galerie — Nos réalisations"
  description={`Découvrez nos chantiers de déménagement à Montpellier et partout en France. Photos de nos interventions résidentielles, professionnelles et longue distance.`}
>
  <Header slot="header" />

  <!-- Hero -->
  <section class="relative overflow-hidden bg-dark py-20 sm:py-24">
    <div class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
      <div class="absolute -right-32 -top-32 size-96 rounded-full bg-primary/20 blur-3xl"></div>
      <div class="absolute -bottom-24 -left-24 size-72 rounded-full bg-primary/10 blur-3xl"></div>
    </div>

    <div class="relative mx-auto max-w-site px-4 sm:px-6">
      <div class="mx-auto max-w-2xl text-center">
        <div class="inline-flex items-center gap-2 rounded-full border border-primary/30 bg-primary/10 px-4 py-1.5">
          <span class="size-2 rounded-full bg-primary" aria-hidden="true"></span>
          <span class="text-topper font-bold uppercase tracking-widest text-primary">Nos réalisations</span>
        </div>
        <h1 class="mt-5 font-heading text-h1 font-bold uppercase leading-tight text-primary-fg">
          Chaque déménagement, <span class="text-primary">géré avec soin.</span>
        </h1>
        <p class="mt-4 text-lg leading-relaxed text-primary-fg/60">
          Aperçu de nos interventions récentes — résidentielles, professionnelles et longue distance.
        </p>
      </div>

      <!-- Stats row -->
      <div class="mt-12 flex flex-wrap items-center justify-center gap-8 border-t border-primary-fg/10 pt-10">
        {stats.map(({ value, label }) => (
          <div class="text-center">
            <p class="font-heading text-3xl font-bold text-primary-fg">{value}</p>
            <p class="mt-0.5 text-sm text-primary-fg/50">{label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Gallery -->
  <section class="bg-background py-section">
    <div class="mx-auto max-w-site px-4 sm:px-6">

      <!-- Filter tabs -->
      <div class="mb-10 flex flex-wrap gap-2" role="tablist" aria-label="Filtrer par catégorie">
        {categories.map((cat, i) => (
          <button
            type="button"
            role="tab"
            aria-selected={i === 0 ? 'true' : 'false'}
            data-filter={cat}
            class:list={[
              'gallery-filter rounded-full border-2 px-4 py-1.5 text-sm font-semibold transition-all',
              i === 0
                ? 'border-primary bg-primary text-primary-foreground'
                : 'border-border bg-background text-muted-foreground hover:border-primary/40 hover:text-foreground',
            ]}
          >
            {cat}
          </button>
        ))}
      </div>

      <!-- Masonry grid -->
      <div id="gallery-grid" class="columns-1 gap-4 sm:columns-2 lg:columns-3 [column-fill:balance]">
        {photos.map(({ src, alt, cat }, i) => (
          <div
            class="gallery-item group relative mb-4 cursor-pointer overflow-hidden rounded-2xl bg-card"
            data-cat={cat}
            data-index={i}
            data-src={src}
            data-alt={alt}
          >
            <!-- Skeleton -->
            <div class="absolute inset-0 animate-pulse bg-linear-to-r from-card via-border to-card" aria-hidden="true" data-skeleton />

            <img
              src={src}
              alt={alt}
              loading="lazy"
              decoding="async"
              class="gallery-img w-full object-cover opacity-0 transition-all duration-500 group-hover:scale-105"
              data-gallery-img
            />

            <!-- Overlay -->
            <div class="absolute inset-0 flex flex-col justify-between bg-linear-to-t from-dark/80 via-transparent to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100 p-4">
              <div class="flex justify-end">
                <span class="rounded-full bg-primary/90 px-2.5 py-0.5 text-xs font-semibold text-primary-foreground backdrop-blur-sm">
                  {cat}
                </span>
              </div>
              <div class="flex items-end justify-between gap-3">
                <p class="text-sm font-medium text-white leading-snug">{alt}</p>
                <span class="flex size-9 shrink-0 items-center justify-center rounded-full bg-white/20 backdrop-blur-sm text-white">
                  <TablerIcon name="plus" class="text-base leading-none" />
                </span>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Empty state (hidden by default) -->
      <div id="gallery-empty" class="hidden py-20 text-center">
        <div class="mx-auto flex size-16 items-center justify-center rounded-full bg-muted text-muted-foreground">
          <TablerIcon name="package" class="text-2xl leading-none" />
        </div>
        <p class="mt-4 font-semibold text-foreground">Aucune photo dans cette catégorie</p>
        <p class="mt-1 text-sm text-muted-foreground">Consultez une autre catégorie.</p>
      </div>

    </div>
  </section>

  <!-- Lightbox -->
  <div
    id="lightbox"
    class="fixed inset-0 z-100 hidden items-center justify-center bg-black/90 backdrop-blur-sm"
    aria-modal="true"
    role="dialog"
    aria-label="Aperçu photo"
  >
    <button id="lb-close" type="button" aria-label="Fermer"
      class="absolute right-4 top-4 flex size-10 items-center justify-center rounded-full bg-white/10 text-white transition hover:bg-white/20">
      <TablerIcon name="x" class="text-xl leading-none" />
    </button>

    <button id="lb-prev" type="button" aria-label="Précédente"
      class="absolute left-3 top-1/2 -translate-y-1/2 flex size-11 items-center justify-center rounded-full bg-white/10 text-white transition hover:bg-white/20 sm:left-6">
      <TablerIcon name="chevron-right" class="rotate-180 text-xl leading-none" />
    </button>

    <button id="lb-next" type="button" aria-label="Suivante"
      class="absolute right-3 top-1/2 -translate-y-1/2 flex size-11 items-center justify-center rounded-full bg-white/10 text-white transition hover:bg-white/20 sm:right-6">
      <TablerIcon name="chevron-right" class="text-xl leading-none" />
    </button>

    <div class="mx-auto flex max-w-4xl flex-col items-center gap-4 px-16">
      <img id="lb-img" src="" alt="" class="max-h-[75vh] w-auto max-w-full rounded-xl object-contain shadow-2xl" />
      <div class="flex items-center gap-3">
        <span id="lb-cat" class="rounded-full bg-primary/80 px-3 py-1 text-xs font-semibold text-white"></span>
        <p id="lb-caption" class="text-sm text-white/80"></p>
      </div>
      <p id="lb-counter" class="text-xs text-white/40"></p>
    </div>
  </div>

  <CTA />
  <Footer slot="footer" />
</BaseLayout>

<script>
  // ── Filter ─────────────────────────────────────────────────────────────────
  function initFilter() {
    const filters = document.querySelectorAll<HTMLButtonElement>('.gallery-filter');
    const items   = document.querySelectorAll<HTMLElement>('.gallery-item');
    const empty   = document.getElementById('gallery-empty');

    filters.forEach((btn) => {
      btn.addEventListener('click', () => {
        const cat = btn.dataset.filter ?? 'Tout';

        filters.forEach((b) => {
          const active = b === btn;
          b.setAttribute('aria-selected', String(active));
          b.classList.toggle('border-primary', active);
          b.classList.toggle('bg-primary', active);
          b.classList.toggle('text-primary-foreground', active);
          b.classList.toggle('border-border', !active);
          b.classList.toggle('bg-background', !active);
          b.classList.toggle('text-muted-foreground', !active);
        });

        let visible = 0;
        items.forEach((item) => {
          const show = cat === 'Tout' || item.dataset.cat === cat;
          item.style.display = show ? '' : 'none';
          if (show) visible++;
        });

        empty?.classList.toggle('hidden', visible > 0);
      });
    });
  }

  // ── Image load ────────────────────────────────────────────────────────────
  function initImages() {
    document.querySelectorAll<HTMLElement>('[data-gallery-img]').forEach((img) => {
      const skeleton = img.closest('.gallery-item')?.querySelector('[data-skeleton]');

      const onLoad = () => {
        img.classList.remove('opacity-0');
        skeleton?.remove();
      };
      const onError = () => { skeleton?.remove(); };

      if ((img as HTMLImageElement).complete) {
        (img as HTMLImageElement).naturalWidth > 0 ? onLoad() : onError();
        return;
      }
      img.addEventListener('load', onLoad, { once: true });
      img.addEventListener('error', onError, { once: true });
    });
  }

  // ── Lightbox ──────────────────────────────────────────────────────────────
  function initLightbox() {
    const lb       = document.getElementById('lightbox')!;
    const lbImg    = document.getElementById('lb-img') as HTMLImageElement;
    const lbCap    = document.getElementById('lb-caption')!;
    const lbCat    = document.getElementById('lb-cat')!;
    const lbCount  = document.getElementById('lb-counter')!;
    const btnClose = document.getElementById('lb-close')!;
    const btnPrev  = document.getElementById('lb-prev')!;
    const btnNext  = document.getElementById('lb-next')!;

    let visibleItems: HTMLElement[] = [];
    let current = 0;

    const getVisible = () =>
      Array.from(document.querySelectorAll<HTMLElement>('.gallery-item')).filter(
        (el) => el.style.display !== 'none',
      );

    const open = (index: number) => {
      visibleItems = getVisible();
      current = Math.max(0, Math.min(index, visibleItems.length - 1));
      show();
      lb.classList.remove('hidden');
      lb.classList.add('flex');
      document.body.style.overflow = 'hidden';
    };

    const close = () => {
      lb.classList.add('hidden');
      lb.classList.remove('flex');
      document.body.style.overflow = '';
    };

    const show = () => {
      const el = visibleItems[current];
      if (!el) return;
      lbImg.src = el.dataset.src ?? '';
      lbImg.alt = el.dataset.alt ?? '';
      lbCap.textContent = el.dataset.alt ?? '';
      lbCat.textContent = el.dataset.cat ?? '';
      lbCount.textContent = `${current + 1} / ${visibleItems.length}`;
    };

    document.querySelectorAll<HTMLElement>('.gallery-item').forEach((item) => {
      item.addEventListener('click', () => {
        const idx = getVisible().indexOf(item);
        if (idx >= 0) open(idx);
      });
    });

    btnClose.addEventListener('click', close);
    btnPrev.addEventListener('click', () => { current = (current - 1 + visibleItems.length) % visibleItems.length; show(); });
    btnNext.addEventListener('click', () => { current = (current + 1) % visibleItems.length; show(); });

    lb.addEventListener('click', (e) => { if (e.target === lb) close(); });

    document.addEventListener('keydown', (e) => {
      if (lb.classList.contains('hidden')) return;
      if (e.key === 'Escape') close();
      if (e.key === 'ArrowLeft')  { current = (current - 1 + visibleItems.length) % visibleItems.length; show(); }
      if (e.key === 'ArrowRight') { current = (current + 1) % visibleItems.length; show(); }
    });
  }

  function init() { initFilter(); initImages(); initLightbox(); }
  init();
  document.addEventListener('astro:after-swap', init);
</script>
