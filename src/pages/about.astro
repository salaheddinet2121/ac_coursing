---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Banner from '../components/Banner.astro';
import CTA from '../components/CTA.astro';
import TablerIcon from '../components/TablerIcon.astro';
import { Image } from 'astro:assets';
import { brand } from '../config/brand';
import { client } from '../data/client';

const commitments = [
  "Ponctualité et équipe joignable avant, pendant et après l'intervention.",
  'Prix annoncé = prix facturé, sauf changement de périmètre validé avec vous.',
  'Protection du mobilier, assurance transport et soin sur les objets fragiles.',
];
---

<BaseLayout
  title="À propos"
  description={`Découvrez ${brand.name}, déménageur à Montpellier depuis 2015. Prix fixe garanti, équipe ponctuelle et assurance transport incluse.`}
  schema={{
    '@context': 'https://schema.org',
    '@type': 'MovingCompany',
    name: client.name,
    telephone: client.phoneForTel,
    url: client.domain,
    foundingDate: '2015',
    address: {
      '@type': 'PostalAddress',
      addressLocality: client.address.city,
      addressRegion: client.address.state,
      postalCode: client.address.zip,
      addressCountry: client.address.country,
    },
  }}
>
  <Header slot="header" />

  <Banner title="À propos" />

  <section class="py-section">
    <div class="mx-auto grid max-w-site grid-cols-1 items-center gap-8 px-4 sm:px-6 lg:grid-cols-2 lg:gap-14">
      <div class="overflow-hidden rounded-lg border border-border shadow-lg">
        <Image
          src="https://images.unsplash.com/photo-1595079676339-1534801ad6cf?w=1000&q=80"
          alt="Équipe de déménageurs en train de charger un camion"
          width={1000}
          height={750}
          loading="lazy"
          class="size-full object-cover"
        />
      </div>
      <div class="space-y-5">
        <span class="text-topper font-bold uppercase tracking-widest text-primary">Notre structure</span>
        <h2 class="font-heading text-h2 font-bold uppercase text-text">Une équipe cadrée, un interlocuteur unique</h2>
        <p class="text-text-muted leading-relaxed">
          AC Coursing accompagne les déménagements à Montpellier et dans toute la région depuis 2015. Nous intervenons aussi sur les trajets longue distance, les besoins de stockage, les débarras et les transferts professionnels.
        </p>
        <p class="text-text-muted leading-relaxed">
          Notre approche est simple: cadrage précis, devis fixe, planning clair et exécution propre. L'objectif est de réduire la friction côté client, pas de la déplacer.
        </p>
        <ul class="space-y-3 pt-2" role="list">
          {commitments.map((item) => (
            <li class="flex items-start gap-3">
              <TablerIcon name="check" class="mt-0.5 text-xl leading-none shrink-0 text-primary" />
              <span class="text-text">{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <CTA />

  <Footer slot="footer" />
</BaseLayout>
