---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Banner from '../../components/Banner.astro';
import { brand } from '../../config/brand';
import { client } from '../../data/client';

const error = Astro.url.searchParams.get('error');
---

<BaseLayout title="Contact — AC Coursing Déménagement Montpellier" description="Demandez un devis gratuit pour votre déménagement à Montpellier. Sans engagement, réponse sous 24h avec un prix fixe garanti et assurance transport incluse.">
  <Header slot="header" />

  <Banner title="Contact" />

  <section class="py-section">
    <div class="mx-auto grid max-w-site grid-cols-1 gap-10 px-4 sm:px-6 lg:grid-cols-5 lg:gap-14">
      <div class="lg:col-span-3">
        <h2 class="font-heading text-h2 font-bold uppercase text-text">Demander un devis</h2>
        <p class="mb-8 mt-2 text-text-muted">
          Donnez-nous les informations utiles: départ, arrivée, date souhaitée et volume estimé. Nous revenons vers vous sous 24h.
        </p>

        {error && (
          <div class="mb-6 rounded-md border border-red-300 bg-red-50 px-4 py-3 text-sm text-red-700">
            {error === 'validation'
              ? 'Merci de renseigner au minimum votre nom et votre téléphone.'
              : "L'envoi a échoué. Vérifiez la configuration SMTP du serveur puis réessayez."}
          </div>
        )}

        <form
          name="contact"
          method="POST"
          action="/api/contact"
          class="flex flex-col gap-5"
        >
          <p class="hidden" aria-hidden="true">
            <label>Leave this empty: <input name="bot-field" tabindex="-1" autocomplete="off" /></label>
          </p>

          <label class="flex flex-col gap-1.5">
            <span class="text-sm font-medium text-text">Nom <span class="text-primary" aria-hidden="true">*</span></span>
            <input type="text" name="name" required autocomplete="name" class="min-h-[44px] rounded-md border border-border bg-background px-4 py-2.5 text-text transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20" />
          </label>

          <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
            <label class="flex flex-col gap-1.5">
              <span class="text-sm font-medium text-text">Téléphone <span class="text-primary" aria-hidden="true">*</span></span>
              <input type="tel" name="phone" required autocomplete="tel" inputmode="tel" class="min-h-[44px] rounded-md border border-border bg-background px-4 py-2.5 text-text transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20" />
            </label>
            <label class="flex flex-col gap-1.5">
              <span class="text-sm font-medium text-text">Email</span>
              <input type="email" name="email" autocomplete="email" class="min-h-[44px] rounded-md border border-border bg-background px-4 py-2.5 text-text transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20" />
            </label>
          </div>

          <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
            <label class="flex flex-col gap-1.5">
              <span class="text-sm font-medium text-text">Adresse de départ</span>
              <input type="text" name="departure" class="min-h-[44px] rounded-md border border-border bg-background px-4 py-2.5 text-text transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20" />
            </label>
            <label class="flex flex-col gap-1.5">
              <span class="text-sm font-medium text-text">Adresse d'arrivée</span>
              <input type="text" name="destination" class="min-h-[44px] rounded-md border border-border bg-background px-4 py-2.5 text-text transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20" />
            </label>
          </div>

          <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
            <label class="flex flex-col gap-1.5">
              <span class="text-sm font-medium text-text">Date souhaitée</span>
              <input type="text" name="move_date" placeholder="Ex: 14 juin 2026" class="min-h-[44px] rounded-md border border-border bg-background px-4 py-2.5 text-text transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20" />
            </label>
            <label class="flex flex-col gap-1.5">
              <span class="text-sm font-medium text-text">Volume estimé</span>
              <input type="text" name="volume" placeholder="Ex: T3, 35 m³" class="min-h-[44px] rounded-md border border-border bg-background px-4 py-2.5 text-text transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20" />
            </label>
          </div>

          <label class="flex flex-col gap-1.5">
            <span class="text-sm font-medium text-text">Précisions</span>
            <textarea name="message" rows="5" class="min-h-[120px] resize-y rounded-md border border-border bg-background px-4 py-2.5 text-text transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"></textarea>
          </label>

          <button type="submit" class="mt-2 inline-flex min-h-[44px] cursor-pointer items-center justify-center self-start rounded-md bg-primary px-8 py-3 text-base font-bold text-primary-foreground shadow-sm transition-opacity hover:opacity-90 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary">
            Envoyer la demande
          </button>
        </form>
      </div>

      <aside class="space-y-8 lg:col-span-2">
        <div>
          <h3 class="font-heading text-lg font-semibold text-text">Téléphone</h3>
          <a href={`tel:${client.phoneForTel}`} class="mt-1 block font-medium text-primary-light transition-colors hover:text-primary">{client.phoneFormatted}</a>
        </div>

        <div>
          <h3 class="font-heading text-lg font-semibold text-text">Email</h3>
          <a href={`mailto:${client.email}`} class="mt-1 block font-medium text-primary-light transition-colors hover:text-primary">{client.email}</a>
        </div>

        <div>
          <h3 class="font-heading text-lg font-semibold text-text">Zone principale</h3>
          <a href={client.address.mapLink} target="_blank" rel="noopener noreferrer" class="mt-1 block text-text-muted transition-colors hover:text-text">
            {client.address.city}, Hérault et départements voisins
          </a>
        </div>

        <div>
          <h3 class="font-heading text-lg font-semibold text-text">Disponibilité</h3>
          <p class="mt-1 text-text-muted">
            Lundi – samedi: 7h – 20h<br />
            Longue distance et urgence: sur demande
          </p>
        </div>
      </aside>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
