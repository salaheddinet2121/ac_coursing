---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Banner from '../components/Banner.astro';
import CTA from '../components/CTA.astro';
import TablerIcon from '../components/TablerIcon.astro';
import { brand } from '../config/brand';
import { client } from '../data/client';
import { getPlacesData, formatRating } from '../lib/google-places';

const places = await getPlacesData();
const ratingDisplay = formatRating(places.rating);

const reviews = [
  { quote: "J'ai fait appel à AC Coursing pour mon déménagement. Tout s'est vraiment bien passé et les professionnels ont été très efficaces.", name: 'Anaïs Foulu', location: 'Montpellier', rating: 5 },
  { quote: 'Perfect professional level. Respect.', name: 'Davidus Saitama', location: 'Montpellier', rating: 5 },
  { quote: "Équipe très réactive et soigneuse. Rien n'a été cassé, tout était bien protégé.", name: 'Marie L.', location: 'Castelnau-le-Lez', rating: 5 },
  { quote: 'Déménagement rapide et sans stress. Le prix annoncé était le prix payé.', name: 'Thomas R.', location: 'Lattes', rating: 5 },
  { quote: "Troisième déménagement avec eux. Toujours impeccable, toujours à l'heure.", name: 'Sophie M.', location: 'Montpellier', rating: 5 },
  { quote: "Très bon suivi du devis jusqu'à la remise des clés. Je recommande.", name: 'Pol Kamal', location: 'Juvignac', rating: 5 },
];
---

<BaseLayout
  title={`Avis clients — ${brand.name} Montpellier`}
  description={`${places.reviewCount} avis Google vérifiés pour AC Coursing. Fiabilité, ponctualité et prix clairs : découvrez pourquoi nos clients nous recommandent à Montpellier.`}
  schema={{
    '@context': 'https://schema.org',
    '@type': 'MovingCompany',
    name: client.name,
    telephone: client.phoneForTel,
    url: client.domain,
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: String(places.rating),
      reviewCount: String(places.reviewCount),
      bestRating: '5',
    },
  }}
>
  <Header slot="header" />

  <Banner title="Avis" />

  <section class="py-section">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <div class="mx-auto mb-10 max-w-2xl text-center lg:mb-14">
        <h2 class="font-heading text-h2 font-bold uppercase text-text">Ce que disent les clients</h2>
        <p class="mt-3 text-text-muted leading-relaxed">
          Plus de {places.reviewCount} avis vérifiés sur Google. Fiabilité, ponctualité et prix clairs: ce que nos clients retiennent systématiquement.
        </p>
      </div>

      <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
        {reviews.map(({ quote, name, location, rating = 5 }) => (
          <div class="flex flex-col rounded-lg border border-border bg-background p-6 shadow-sm">
            <div class="mb-4 flex gap-1" aria-label={`Noté ${rating} sur 5`}>
              {Array.from({ length: 5 }).map((_, i) => (
                <TablerIcon name="star-filled" class:list={['text-xl leading-none', i < rating ? 'text-primary' : 'text-border']} />
              ))}
            </div>
            <blockquote class="flex-1 text-text-muted leading-relaxed">&ldquo;{quote}&rdquo;</blockquote>
            <div class="mt-4 border-t border-border pt-4">
              <p class="font-semibold text-text">{name}</p>
              <p class="text-sm text-text-muted">{location}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTA />

  <Footer slot="footer" />
</BaseLayout>
