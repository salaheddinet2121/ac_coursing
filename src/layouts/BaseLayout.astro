---
/**
 * Base layout — wraps every page.
 *
 * Astro 6 features used:
 *  • <Font />         — built-in font optimizer from astro.config.mjs fonts array
 *  • <ClientRouter /> — client-side navigation with CSS transition animations
 */
import { Font } from 'astro:assets';
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import { brand } from '../config/brand';
import { client } from '../data/client';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  schema?: Record<string, unknown>;
}

const {
  title = brand.name,
  description = brand.description,
  image = '/og-image.png',
  schema,
} = Astro.props;

const pageTitle = title === brand.name ? title : `${title} — ${brand.name}`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? brand.url);
---

<html lang={brand.locale.split('_')[0]} class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <link rel="canonical" href={canonicalURL} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:url"         content={canonicalURL} />
    <meta property="og:title"       content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={new URL(image, canonicalURL)} />
    <meta property="og:locale"      content={brand.locale} />
    <meta property="og:site_name"   content={brand.name} />

    <!-- Twitter Card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={new URL(image, canonicalURL)} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon/favicon.svg" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon/favicon-96x96.png" />
    <link rel="icon" type="image/x-icon" href="/favicon/favicon.ico" />
    <link rel="manifest" href="/favicon/site.webmanifest" />
    <meta name="theme-color" content="#ffffff" />

    <!-- Fonts -->
    <Font cssVariable="--font-display" preload />
    <Font cssVariable="--font-body"    preload />

    <!-- JSON-LD Structured Data -->
    {schema && (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
    )}

    <!-- Consent Mode v2 — defaults + immediate update if already accepted -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      window.gtag = window.gtag || function gtag(){dataLayer.push(arguments);}

      var _consent = localStorage.getItem('cookie_consent');

      gtag('consent', 'default', {
        analytics_storage:  _consent === 'accepted' ? 'granted' : 'denied',
        ad_storage:         _consent === 'accepted' ? 'granted' : 'denied',
        ad_user_data:       _consent === 'accepted' ? 'granted' : 'denied',
        ad_personalization: _consent === 'accepted' ? 'granted' : 'denied',
      });
      gtag('set', 'ads_data_redaction', true);
      gtag('set', 'url_passthrough', true);
    </script>

    <!-- Google Tag Manager -->
    <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
})(window,document,'script','dataLayer','GTM-T9KGJ6CN');</script>

    <slot name="head" />
    <ClientRouter />
  </head>

  <body class="bg-background text-text antialiased">
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-T9KGJ6CN" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <a
      class="sr-only focus:not-sr-only focus:absolute focus:z-99999 focus:bg-primary focus:text-primary-fg focus:px-4 focus:py-2 focus:rounded-md"
      href="#main"
    >
      Skip to main content
    </a>

    <slot name="header" />

    <main id="main">
      <slot />
    </main>

    <slot name="footer" />

    <script>
      function initReveal() {
        const els = document.querySelectorAll<HTMLElement>('[data-reveal]:not(.revealed)');
        if (!els.length) return;
        const io = new IntersectionObserver((entries) => {
          entries.forEach((e) => {
            if (!e.isIntersecting) return;
            (e.target as HTMLElement).classList.add('revealed');
            io.unobserve(e.target);
          });
        }, { threshold: 0.12 });
        els.forEach((el) => io.observe(el));
      }
      initReveal();
      document.addEventListener('astro:after-swap', initReveal);
    </script>

    <!-- Cookie consent banner -->
    <div
      id="cookie-banner"
      class="fixed bottom-0 left-0 right-0 z-9999 bg-card border-t border-border shadow-lg px-4 py-4 sm:px-6"
      style="display:none"
      role="dialog"
      aria-modal="false"
      aria-label="Consentement aux cookies"
    >
      <div class="mx-auto flex max-w-site flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
        <p class="text-sm text-muted-foreground leading-relaxed">
          Ce site utilise des cookies analytiques (Google Analytics) pour mesurer l'audience et améliorer votre expérience.
          <a href="/politique-confidentialite" class="text-primary underline underline-offset-2 hover:opacity-80">En savoir plus</a>.
        </p>
        <div class="flex shrink-0 gap-2">
          <button
            id="cookie-reject"
            class="rounded-full border border-border bg-background px-5 py-2 text-sm font-semibold text-muted-foreground transition hover:border-primary/40 hover:text-primary"
          >
            Refuser
          </button>
          <button
            id="cookie-accept"
            class="rounded-full bg-primary px-5 py-2 text-sm font-bold text-primary-foreground shadow transition hover:opacity-90"
          >
            Accepter
          </button>
        </div>
      </div>
    </div>

    <script is:inline>
      (function () {
        var GRANTED = {
          analytics_storage:  'granted',
          ad_storage:         'granted',
          ad_user_data:       'granted',
          ad_personalization: 'granted',
        };

        function updateConsent() {
          gtag('consent', 'update', GRANTED);
        }

        var banner = document.getElementById('cookie-banner');
        var stored = localStorage.getItem('cookie_consent');

        if (stored === 'accepted') {
          updateConsent();
        } else if (!stored) {
          banner.style.display = 'block';
        }

        document.addEventListener('astro:after-swap', function () {
          if (localStorage.getItem('cookie_consent') === 'accepted') updateConsent();
        });

        document.getElementById('cookie-accept').addEventListener('click', function () {
          localStorage.setItem('cookie_consent', 'accepted');
          banner.style.display = 'none';
          updateConsent();
        });

        document.getElementById('cookie-reject').addEventListener('click', function () {
          localStorage.setItem('cookie_consent', 'rejected');
          banner.style.display = 'none';
        });
      })();
    </script>

    <!-- WhatsApp floating button -->
    <a
      href={`https://wa.me/33${client.phoneForTel.slice(1)}`}
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Contacter sur WhatsApp"
      class="fixed bottom-5 right-4 z-50 flex size-14 items-center justify-center rounded-full bg-[#25D366] shadow-lg shadow-[#25D366]/30 transition-all hover:scale-110 hover:shadow-xl hover:shadow-[#25D366]/40 sm:bottom-6 sm:right-6"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="size-6 fill-white" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
    </a>
  </body>
</html>
