---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CTA from '../components/CTA.astro';
import TablerIcon from '../components/TablerIcon.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  author?: string;
}

const { title, description, date, author = 'Team' } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const schema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  datePublished: date.toISOString(),
  author: { '@type': 'Person', name: author },
  publisher: {
    '@type': 'Organization',
    name: 'AC Coursing Déménagement',
    url: 'https://ac-coursing.fr',
  },
};
---

<BaseLayout title={title} description={description} schema={schema}>
  <Header slot="header" />

  <section class="bg-primary py-14 sm:py-16 lg:py-20">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <nav aria-label="Breadcrumb" class="mb-4">
        <ol class="flex items-center gap-1.5 text-sm text-primary-fg/60">
          <li><a href="/" class="transition-colors hover:text-primary-fg">Home</a></li>
          <li class="flex items-center gap-1.5">
            <TablerIcon name="chevron-right" class="size-3.5" />
            <a href="/blog" class="transition-colors hover:text-primary-fg">Blog</a>
          </li>
          <li class="flex items-center gap-1.5">
            <TablerIcon name="chevron-right" class="size-3.5" />
            <span aria-current="page" class="text-primary-fg">{title}</span>
          </li>
        </ol>
      </nav>

      <h1 class="font-heading text-h1 font-bold uppercase text-primary-fg">{title}</h1>
      <div class="mt-3 flex items-center gap-3 text-sm text-primary-fg/70">
        <span>{author}</span>
        <span aria-hidden="true">&bull;</span>
        <time datetime={date.toISOString()}>{formattedDate}</time>
      </div>
    </div>
  </section>

  <section class="py-section">
    <div class="mx-auto max-w-3xl px-4 sm:px-6">
      <article class="prose prose-lg max-w-none prose-headings:font-heading prose-headings:uppercase prose-a:text-primary-light hover:prose-a:text-primary">
        <slot />
      </article>

      <div class="mt-10 border-t border-border pt-6">
        <a
          href="/blog"
          class="inline-flex items-center gap-2 text-sm font-semibold text-primary transition-colors hover:text-primary-light"
        >
          <TablerIcon name="arrow-right" class="size-4 rotate-180" />
          Retour au blog
        </a>
      </div>
    </div>
  </section>

  <CTA />

  <Footer slot="footer" />
</BaseLayout>
