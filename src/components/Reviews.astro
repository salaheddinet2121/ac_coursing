---
import TablerIcon from './TablerIcon.astro';
import { client } from '../data/client';

interface Review {
  quote: string;
  name: string;
  location: string;
  rating?: number;
}

interface Props {
  topper?: string;
  heading?: string;
  reviews?: Review[];
}

const {
  topper = '194 avis vérifiés',
  heading = '5,0 / 5 sur Google',
  reviews = [
    { quote: "J'ai fait appel à AC Coursing pour mon déménagement le mardi 14 octobre. Tout s'est vraiment bien passé et les professionnels ont été très efficaces !", name: 'Anaïs Foulu', location: 'Montpellier', rating: 5 },
    { quote: 'Perfect professional level. Respect.', name: 'Davidus Saitama', location: 'Montpellier', rating: 5 },
    { quote: 'Great.', name: 'Pol Kamal', location: 'Montpellier', rating: 5 },
    { quote: "Équipe très réactive et soigneuse. Rien n'a été cassé, tout était bien protégé. Je recommande les yeux fermés.", name: 'Marie L.', location: 'Castelnau-le-Lez', rating: 5 },
    { quote: "Déménagement rapide et sans stress. Le prix annoncé était le prix payé. Ça change des autres.", name: 'Thomas R.', location: 'Lattes', rating: 5 },
    { quote: "Troisième déménagement avec eux. Toujours impeccable, toujours à l'heure. L'équipe est au top.", name: 'Sophie M.', location: 'Montpellier', rating: 5 },
  ],
} = Astro.props;
---

<section id="avis" class="bg-card py-section">
  <div class="mx-auto max-w-site px-4 sm:px-6">

    <div class="mx-auto mb-10 max-w-2xl text-center lg:mb-14" data-reveal>
      <div class="inline-flex items-center gap-2 rounded-full border border-primary/30 bg-primary/10 px-4 py-1.5">
        <span class="size-2 rounded-full bg-primary"></span>
        <span class="text-topper font-bold uppercase tracking-widest text-primary">{topper}</span>
      </div>
      <h2 class="mt-4 font-heading text-h2 font-bold uppercase text-primary">{heading}</h2>
    </div>

    <ul class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3" role="list">
      {reviews.map(({ quote, name, location, rating = 5 }, i) => (
        <li class="flex flex-col rounded-xl border border-border bg-background p-6 shadow-sm" data-reveal style={`transition-delay:${i * 80}ms`}>
          <!-- Stars -->
          <div class="mb-4 flex gap-1" aria-label={`Noté ${rating} sur 5`}>
            {Array.from({ length: 5 }).map((_, i) => (
              <TablerIcon
                name="star-filled"
                class:list={['text-xl leading-none', i < rating ? 'text-primary' : 'text-border']}
              />
            ))}
          </div>

          <blockquote class="flex-1 leading-relaxed text-muted-foreground">
            &ldquo;{quote}&rdquo;
          </blockquote>

          <div class="mt-5 flex items-center gap-3 border-t border-border pt-4">
            <div class="flex size-9 items-center justify-center rounded-full bg-primary text-primary-foreground text-sm font-bold">
              {name.charAt(0)}
            </div>
            <div>
              <p class="text-sm font-semibold text-primary">{name}</p>
              <p class="text-xs text-muted-foreground">{location}</p>
            </div>
          </div>
        </li>
      ))}
    </ul>

    <div class="mt-8 text-center">
      <a
        href={client.socials.google}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex min-h-[44px] items-center gap-2 rounded-md border border-border bg-card px-5 py-3 text-sm font-semibold text-muted-foreground transition-all hover:border-primary/40 hover:text-primary"
      >
        <TablerIcon name="brand-google" class="text-xl leading-none" />
        Voir les avis Google
      </a>
    </div>

  </div>
</section>
