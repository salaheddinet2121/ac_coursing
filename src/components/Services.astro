---
import TablerIcon from './TablerIcon.astro';

interface ServiceItem {
  title: string;
  description: string;
  href?: string;
  icon: string;
  badge?: string;
}

interface Props {
  topper?: string;
  heading?: string;
  description?: string;
  services?: ServiceItem[];
}

const {
  topper = 'Nos services',
  heading = 'Tout inclus. Zéro surprise.',
  description = 'Nous couvrons les déménagements résidentiels, professionnels et longue distance avec une logistique cadrée de bout en bout.',
  services = [
    {
      title: 'Déménagement au sein de l\'État',
      description: "Transport et installation de vos biens partout en France. Notre équipe gère tout : emballage, chargement, livraison et mise en place dans votre nouveau logement. Service rapide, fiable et soigné de bout en bout.",
      href: '/services',
      icon: 'building',
    },
    {
      title: 'Déménagement avec mise en carton',
      description: "Nous prenons en charge l'emballage complet de vos affaires avec du matériel professionnel. Cartons renforcés, papier bulle et protections adaptées à vos objets fragiles. Votre déménagement est sécurisé avant même le jour J.",
      href: '/services',
      icon: 'box',
    },
    {
      title: 'Déménagement d\'objets volumineux',
      description: "Canapés, armoires, électroménager, pianos : nous déplaçons vos objets encombrants avec le matériel adéquat. Nos déménageurs sécurisent et transportent chaque pièce volumineuse sans risque d'endommagement.",
      href: '/services',
      icon: 'sofa',
    },
    {
      title: 'Déménagement local',
      description: "Vous déménagez à Montpellier ou alentours ? Notre équipe intervient rapidement sur toute la région : Castelnau-le-Lez, Lattes, Saint-Jean-de-Védas, Béziers et plus. Service local soigné et disponible 7j/7.",
      href: '/services',
      icon: 'map-pin',
    },
    {
      title: 'Déménagement pour seniors',
      description: "Un service attentionné dédié aux personnes âgées. Nous accompagnons chaque étape avec patience et soin, du tri au placement des meubles, pour un déménagement serein, sans stress et en toute confiance.",
      href: '/services',
      icon: 'heart',
    },
    {
      title: 'Déménagements longue distance',
      description: "Vous partez loin ? Nous assurons vos déménagements longue distance partout en France. Emballage sécurisé, transport direct et livraison dans les délais convenus pour un déménagement sans mauvaise surprise.",
      href: '/services',
      icon: 'truck-delivery',
    },
    {
      title: 'Enlèvement de déchets liés à un déménagement',
      description: "Débarras de mobilier, évacuation d'encombrants et collecte de déchets lors de votre déménagement. Nous gérons tout ce que vous ne souhaitez pas conserver, avec un traitement responsable et respectueux de l'environnement.",
      href: '/services',
      icon: 'trash',
    },
  ],
} = Astro.props;
---

<section id="services" class="bg-background py-section">
  <div class="mx-auto max-w-site px-4 sm:px-6">

    <div class="mx-auto mb-10 max-w-2xl text-center lg:mb-14" data-reveal>
      <div class="inline-flex items-center gap-2 rounded-full border border-primary/30 bg-primary/10 px-4 py-1.5">
        <span class="size-2 rounded-full bg-primary"></span>
        <span class="text-topper font-bold uppercase tracking-widest text-primary">{topper}</span>
      </div>
      <h2 class="mt-4 font-heading text-h2 font-bold uppercase text-primary">{heading}</h2>
      <p class="mt-3 leading-relaxed text-muted-foreground">{description}</p>
    </div>

    <ul class="grid grid-cols-1 gap-6 md:grid-cols-2" role="list">
      {services.map((service, i) => (
        <li data-reveal style={`transition-delay:${i * 80}ms`}>
          <a
            href={service.href || '/services'}
            aria-label={`En savoir plus sur ${service.title}`}
            class="group flex h-full gap-5 rounded-xl border border-border bg-card p-6 shadow-sm transition-all duration-200 hover:border-primary/40 hover:shadow-md"
          >
            <div class="flex size-12 shrink-0 items-center justify-center rounded-lg bg-primary/10 text-primary transition-colors group-hover:bg-primary group-hover:text-primary-foreground">
              <TablerIcon name={service.icon} filled class="text-xl leading-none" />
            </div>
            <div class="flex-1">
              <h3 class="font-heading text-h3 font-semibold text-primary">{service.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-muted-foreground">{service.description}</p>
              <span class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-primary transition-colors">
                Voir le détail
                <TablerIcon name="chevron-right" class="text-base leading-none transition-transform group-hover:translate-x-0.5" />
              </span>
            </div>
          </a>
        </li>
      ))}
    </ul>

  </div>
</section>
