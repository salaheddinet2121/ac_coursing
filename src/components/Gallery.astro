---
import TablerIcon from './TablerIcon.astro';

interface GalleryImage { src: string; alt: string; }

interface Props {
  topper?: string;
  heading?: string;
  description?: string;
  images?: GalleryImage[];
  ctaLabel?: string;
  ctaHref?: string;
}

const defaultImages: GalleryImage[] = [
  { src: '/images/residentiel/residentiel-03.webp',         alt: 'Déménagement résidentiel' },
  { src: '/images/residentiel/residentiel-04.webp',         alt: 'Chargement soigné' },
  { src: '/images/professionnel/professionnel-01.webp',     alt: 'Déménagement professionnel' },
  { src: '/images/professionnel/professionnel-02.webp',     alt: 'Emballage bureaux' },
  { src: '/images/longue-distance/longue-distance-02.webp', alt: 'Livraison longue distance' },
  { src: '/images/garde-meubles/garde-meubles-01.webp',     alt: 'Garde-meubles sécurisé' },
];

const {
  topper = 'Interventions récentes',
  heading = 'Des chantiers organisés proprement',
  description = "Chargement, stockage, livraison et remise en place: aperçu des types d'interventions que nous gérons au quotidien.",
  images = defaultImages,
  ctaLabel = 'Voir toutes les réalisations',
  ctaHref = '/galerie',
} = Astro.props;
---

<section class="bg-background py-section">
  <div class="mx-auto max-w-site px-4 sm:px-6">
    <div class="mx-auto mb-10 max-w-2xl text-center lg:mb-14">
      <div class="inline-flex items-center gap-2 rounded-full border border-primary/30 bg-primary/10 px-4 py-1.5">
        <span class="size-2 rounded-full bg-primary"></span>
        <span class="text-topper font-bold uppercase tracking-widest text-primary">{topper}</span>
      </div>
      <h2 class="mt-4 font-heading text-h2 font-bold uppercase text-primary">{heading}</h2>
      <p class="mt-3 leading-relaxed text-muted-foreground">{description}</p>
    </div>

    <div class="grid grid-cols-2 gap-3 sm:gap-4 lg:grid-cols-3">
      {images.map(({ src, alt }) => (
        <div class="group relative overflow-hidden rounded-xl aspect-4/3 bg-card" data-gallery-item>
          <div class="absolute inset-0 animate-pulse bg-linear-to-r from-card via-border to-card" aria-hidden="true" data-skeleton />

          <img
            src={src}
            alt={alt}
            loading="lazy"
            decoding="async"
            class="relative size-full object-cover opacity-0 transition-all duration-300 group-hover:scale-105"
            data-gallery-img
          />

          <div class="absolute inset-0 hidden flex-col items-center justify-center gap-2 bg-card text-sm text-muted-foreground" data-error-state aria-label="Image indisponible">
            <TablerIcon name="package" class="text-3xl leading-none opacity-40" />
            <span class="text-xs">Image indisponible</span>
          </div>

          <div class="absolute inset-0 flex items-end bg-linear-to-t from-dark/60 to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100">
            <p class="p-3 text-sm font-medium text-white sm:p-4">{alt}</p>
          </div>
        </div>
      ))}
    </div>

    {ctaLabel && (
      <div class="mt-10 text-center">
        <a
          href={ctaHref}
          class="inline-flex min-h-[48px] items-center gap-2 rounded-md border-2 border-primary px-6 py-3 text-base font-bold text-primary transition-all hover:bg-primary hover:text-primary-foreground"
        >
          {ctaLabel}
          <TablerIcon name="arrow-right" class="text-base leading-none" />
        </a>
      </div>
    )}
  </div>
</section>

<script>
  function initGallery() {
    document.querySelectorAll('[data-gallery-item]').forEach((item) => {
      const img = item.querySelector('[data-gallery-img]');
      const skeleton = item.querySelector('[data-skeleton]');
      const errorState = item.querySelector('[data-error-state]');
      if (!img || !skeleton || !errorState) return;

      function onLoad() {
        img.classList.remove('opacity-0');
        skeleton.remove();
      }

      function onError() {
        skeleton.remove();
        img.classList.add('hidden');
        errorState.classList.remove('hidden');
        errorState.classList.add('flex');
      }

      if (img.complete) {
        img.naturalWidth > 0 ? onLoad() : onError();
        return;
      }

      img.addEventListener('load', onLoad, { once: true });
      img.addEventListener('error', onError, { once: true });
    });
  }

  initGallery();
  document.addEventListener('astro:after-swap', initGallery);
</script>
