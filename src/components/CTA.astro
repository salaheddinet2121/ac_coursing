---
import { client } from '../data/client';
import TablerIcon from './TablerIcon.astro';

interface Props {
  title?: string;
  description?: string;
  buttonText?: string;
  buttonHref?: string;
}

const {
  title       = 'Votre estimation en 4 étapes, en moins de 2 minutes.',
  description = 'Remplissez le formulaire. Nous vous rappelons avec un prix fixe, garanti, et une réponse sous 24h.',
  buttonText  = 'Estimer le coût gratuitement',
  buttonHref  = '/devis',
} = Astro.props;
---

<section class="relative overflow-hidden bg-primary py-16 sm:py-20 lg:py-24">
  <!-- Decorative glow -->
  <div
    class="pointer-events-none absolute -right-24 -top-24 size-80 rounded-full bg-primary-foreground/10 blur-3xl"
    aria-hidden="true"
  ></div>
  <div
    class="pointer-events-none absolute -bottom-20 -left-20 size-60 rounded-full bg-primary-foreground/8 blur-3xl"
    aria-hidden="true"
  ></div>

  <div class="relative mx-auto max-w-site px-4 text-center sm:px-6">
    <h2 class="font-heading text-h2 font-bold uppercase text-primary-foreground" data-reveal>
      {title}
    </h2>
    <p class="mx-auto mt-4 max-w-2xl leading-relaxed text-primary-foreground/75" data-reveal style="transition-delay:80ms">
      {description}
    </p>

    <div class="mt-8 flex flex-col items-center gap-4 sm:flex-row sm:justify-center" data-reveal style="transition-delay:160ms">
      <a
        href={buttonHref}
        class="inline-flex min-h-[48px] items-center justify-center rounded-md bg-background px-8 py-3 text-base font-bold text-primary shadow-md transition-all hover:opacity-90 hover:shadow-lg focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-background"
      >
        {buttonText}
      </a>
      <a
        href={`tel:${client.phoneForTel}`}
        class="inline-flex min-h-[48px] items-center justify-center gap-2 rounded-md border-2 border-primary-foreground/30 px-8 py-3 text-base font-bold text-primary-foreground transition-all hover:border-primary-foreground/70 hover:bg-primary-foreground/10 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-foreground"
      >
        <TablerIcon name="phone" class="text-xl leading-none" />
        {client.phoneFormatted}
      </a>
    </div>

    <p class="mt-5 text-sm text-primary-foreground/60">
      100&nbsp;% gratuit &middot; Sans engagement &middot; Réponse garantie sous 24h
    </p>
  </div>
</section>
