---
import { brand } from '../config/brand';
import { client } from '../data/client';
import TablerIcon from './TablerIcon.astro';

const year = new Date().getFullYear();

const navLinks = [
  { label: 'Services', href: '/#services' },
  { label: 'Comment ça marche', href: '/#comment-ca-marche' },
  { label: 'Avis clients', href: '/#avis' },
  { label: 'Garanties', href: '/#garanties' },
  { label: 'FAQ', href: '/#faq' },
  { label: 'Nous trouver', href: client.address.mapLink },
];
---

<footer class="bg-dark text-primary-fg/70">
  <div class="mx-auto max-w-site px-4 py-12 sm:px-6 lg:py-16">
    <div class="grid grid-cols-1 gap-10 lg:grid-cols-[1.4fr_1fr_1fr]">

      <!-- Brand col -->
      <div>
        <a href="/" class="inline-flex items-center transition-opacity hover:opacity-80" aria-label={brand.name}>
          <img
            src="/logo/full_logo_dark%20(1).svg"
            alt={brand.name}
            width="220"
            height="60"
            class="h-auto w-45 max-w-full sm:w-55"
            loading="eager"
            decoding="async"
          />
          <span class="sr-only">{brand.name}</span>
        </a>
        <p class="mt-3 max-w-sm text-sm leading-relaxed">
          Déménageur de confiance à Montpellier depuis 2015. Devis fixe, équipe ponctuelle, assurance transport incluse et accompagnement partout en France.
        </p>

        <a
          href="/contact"
          class="mt-5 inline-flex min-h-12 items-center gap-2 rounded-md bg-primary px-5 py-2 text-sm font-bold text-primary-foreground transition-all hover:opacity-90"
        >
          Devis gratuit
          <TablerIcon name="arrow-right" class="text-base leading-none" />
        </a>

        <div class="mt-5 flex items-center gap-4">
          {client.socials.google && (
            <a
              href={client.socials.google}
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Google Business"
              class="text-primary-fg/40 transition-colors hover:text-primary"
            >
              <TablerIcon name="brand-google" class="text-xl leading-none" />
            </a>
          )}
        </div>
      </div>

      <!-- Contact col -->
      <div>
        <h3 class="text-sm font-bold uppercase tracking-wider text-primary-fg">Contact</h3>
        <ul class="mt-3 space-y-3 text-sm">
          <li>
            <a href={`tel:${client.phoneForTel}`} class="inline-flex items-center gap-2 transition-colors hover:text-primary">
              <TablerIcon name="phone" class="text-base leading-none" />
              {client.phoneFormatted}
            </a>
          </li>
          <li>
            <a href={`mailto:${client.email}`} class="inline-flex items-center gap-2 transition-colors hover:text-primary">
              <TablerIcon name="mail" class="text-base leading-none" />
              {client.email}
            </a>
          </li>
          <li>
            <a
              href={client.address.mapLink}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-start gap-2 transition-colors hover:text-primary"
            >
              <TablerIcon name="map-pin" class="mt-0.5 text-base leading-none shrink-0" />
              <span>{client.address.lineOne}, {client.address.zip} {client.address.city}, France</span>
            </a>
          </li>
        </ul>
      </div>

      <!-- Nav col -->
      <div>
        <h3 class="text-sm font-bold uppercase tracking-wider text-primary-fg">Navigation</h3>
        <ul class="mt-3 space-y-2">
          {navLinks.map(({ label, href }) => (
            <li>
              <a href={href} target={href.startsWith('http') ? '_blank' : undefined} rel={href.startsWith('http') ? 'noopener noreferrer' : undefined} class="text-sm transition-colors hover:text-primary">{label}</a>
            </li>
          ))}
        </ul>
      </div>

    </div>

    <div class="mt-10 border-t border-primary-fg/10 pt-6 flex flex-col items-center gap-2 text-center text-sm sm:flex-row sm:justify-between">
      <span>&copy; {year} {brand.name}. Tous droits réservés.</span>
      <nav aria-label="Liens légaux" class="flex gap-4">
        <a href="/mentions-legales" class="transition-colors hover:text-primary">Mentions légales</a>
        <a href="/politique-confidentialite" class="transition-colors hover:text-primary">Confidentialité</a>
      </nav>
    </div>
  </div>
</footer>
