---
import TablerIcon from './TablerIcon.astro';

interface Props {
  topper?: string;
  heading?: string;
  description?: string;
  primaryZoneLabel?: string;
  primaryZones?: string[];
  extendedZoneLabel?: string;
  extendedZones?: string[];
  nationalCtaLabel?: string;
  nationalCtaHref?: string;
  footerText?: string;
  footerLinkLabel?: string;
  footerLinkHref?: string;
}

const {
  topper = "Zones d'intervention",
  heading = 'On intervient près de chez vous',
  description = "Basés à Montpellier, nous couvrons tout l'Hérault et les départements voisins. Longue distance ? On vous accompagne partout en France.",
  primaryZoneLabel = 'Zone principale',
  primaryZones = ['Montpellier', 'Castelnau-le-Lez', 'Lattes', 'Pérols', 'Mauguio', 'Juvignac', 'Saint-Jean-de-Védas', 'Grabels'],
  extendedZoneLabel = 'Zone élargie',
  extendedZones = ['Palavas-les-Flots', 'Lunel', 'Sète', 'Béziers', 'Nîmes', 'Agde', 'Frontignan'],
  nationalCtaLabel = 'Demander un devis longue distance',
  nationalCtaHref = '/devis',
  footerText = 'Votre ville n\'est pas listée ?',
  footerLinkLabel = 'Contactez-nous',
  footerLinkHref = '/contact',
} = Astro.props;
---

<section id="zones" class="bg-background py-section">
  <div class="mx-auto max-w-site px-4 sm:px-6">

    <!-- Heading -->
    <div class="mx-auto mb-12 max-w-2xl text-center" data-reveal>
      <div class="inline-flex items-center gap-2 rounded-full border border-primary/30 bg-primary/10 px-4 py-1.5">
        <span class="size-2 rounded-full bg-primary" aria-hidden="true"></span>
        <span class="text-topper font-bold uppercase tracking-widest text-primary">{topper}</span>
      </div>
      <h2 class="mt-4 font-heading text-h2 font-bold uppercase text-primary">{heading}</h2>
      <p class="mt-3 leading-relaxed text-muted-foreground">{description}</p>
    </div>

    <!-- Zone cards -->
    <div class="grid grid-cols-1 gap-0 overflow-hidden rounded-2xl border border-border shadow-sm md:grid-cols-3">

      <!-- Primary zone -->
      <div class="border-b border-border bg-card p-8 md:border-b-0 md:border-r" data-reveal style="transition-delay:0ms">
        <div class="mb-5 flex items-center gap-2">
          <span class="size-2.5 rounded-full bg-primary" aria-hidden="true"></span>
          <span class="text-topper font-bold uppercase tracking-widest text-primary">{primaryZoneLabel}</span>
        </div>
        <ul class="space-y-3" role="list">
          {primaryZones.map((city) => (
            <li class="flex items-center gap-2.5 text-foreground">
              <TablerIcon name="map-pin" filled class="text-base text-primary leading-none shrink-0" />
              {city}
            </li>
          ))}
        </ul>
      </div>

      <!-- Extended zone -->
      <div class="border-b border-border bg-card p-8 md:border-b-0 md:border-r" data-reveal style="transition-delay:100ms">
        <div class="mb-5 flex items-center gap-2">
          <span class="size-2.5 rounded-full bg-muted-foreground" aria-hidden="true"></span>
          <span class="text-topper font-bold uppercase tracking-widest text-muted-foreground">{extendedZoneLabel}</span>
        </div>
        <ul class="space-y-3" role="list">
          {extendedZones.map((city) => (
            <li class="flex items-center gap-2.5 text-foreground">
              <TablerIcon name="map-pin" filled class="text-base text-primary leading-none shrink-0" />
              {city}
            </li>
          ))}
        </ul>
      </div>

      <!-- National CTA card -->
      <div class="flex flex-col justify-between bg-primary p-8 text-primary-foreground" data-reveal style="transition-delay:200ms">
        <div>
          <div class="flex size-12 items-center justify-center rounded-xl bg-primary-foreground/10 mb-5">
            <TablerIcon name="plus" class="text-2xl text-primary-foreground leading-none" />
          </div>
          <h3 class="font-heading text-h3 font-bold text-primary-foreground">Toute la France</h3>
          <p class="mt-3 text-sm leading-relaxed text-primary-foreground/80">
            Déménagement longue distance&nbsp;? Nous prenons en charge les trajets vers toutes les villes françaises.
          </p>
        </div>
        <a
          href={nationalCtaHref}
          class="mt-8 inline-flex items-center gap-1.5 text-sm font-bold text-primary-foreground/90 transition-colors hover:text-primary-foreground"
        >
          {nationalCtaLabel}
          <TablerIcon name="arrow-right" class="text-base leading-none" />
        </a>
      </div>

    </div>

    <!-- Footer note -->
    <p class="mt-6 text-center text-sm text-muted-foreground">
      {footerText}
      <a href={footerLinkHref} class="font-semibold text-primary underline underline-offset-2 hover:opacity-80">
        {footerLinkLabel}
      </a>
      {' '}— on intervient partout.
    </p>

  </div>
</section>
