---
import { brand } from '../config/brand';
import { client } from '../data/client';
import TablerIcon from './TablerIcon.astro';

const nav = [
  { label: 'Accueil',   href: '/' },
  { label: 'Services',  href: '/services' },
  { label: 'Galerie',   href: '/galerie' },
  { label: 'Avis',      href: '/reviews' },
  { label: 'Contact',   href: '/contact' },
];

const currentPath = Astro.url.pathname;
const isActive = (href: string) => {
  const path = href.split('#')[0] || '/';
  return path === currentPath || (path !== '/' && currentPath.startsWith(path));
};
---

<header class="sticky top-0 z-50 w-full border-b border-border/60 bg-background/95 backdrop-blur-md">
  <div class="mx-auto flex max-w-site items-center justify-between gap-6 px-4 py-0 sm:px-6">

    <!-- Logo -->
    <a href="/" class="shrink-0 py-3 transition-opacity hover:opacity-80" aria-label={brand.name}>
      <img
        src="/logo/full_logo.svg"
        alt={brand.name}
        class="h-10 w-auto"
        loading="eager"
        decoding="async"
      />
    </a>

    <!-- Desktop nav -->
    <nav class="hidden items-center gap-1 lg:flex" aria-label="Navigation principale">
      {nav.map(({ label, href }) => (
        <a
          href={href}
          aria-current={isActive(href) ? 'page' : undefined}
          class:list={[
            'relative px-3 py-2 text-sm font-medium rounded-lg transition-colors',
            isActive(href)
              ? 'text-primary bg-primary/8'
              : 'text-foreground/70 hover:text-foreground hover:bg-muted',
          ]}
        >
          {label}
        </a>
      ))}
    </nav>

    <!-- Desktop actions -->
    <div class="hidden items-center gap-3 lg:flex">
      <a
        href={`tel:${client.phoneForTel}`}
        class="flex items-center gap-2 rounded-full border border-border px-4 py-2 text-sm font-semibold text-foreground transition-colors hover:border-primary/40 hover:text-primary"
      >
        <TablerIcon name="phone" class="text-base leading-none text-primary" />
        {client.phoneFormatted}
      </a>
      <a
        href="/devis"
        class="inline-flex items-center gap-2 rounded-full bg-primary px-5 py-2.5 text-sm font-bold text-primary-foreground shadow-sm transition-opacity hover:opacity-90 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
      >
        Devis gratuit
        <TablerIcon name="arrow-right" class="text-sm leading-none" />
      </a>
    </div>

    <!-- Mobile burger -->
    <button
      id="menu-toggle"
      type="button"
      aria-expanded="false"
      aria-controls="mobile-menu"
      class="inline-flex size-10 items-center justify-center rounded-lg text-foreground/70 transition-colors hover:bg-muted lg:hidden"
    >
      <span class="sr-only">Ouvrir le menu</span>
      <span id="menu-icon-open"><TablerIcon name="menu-2" class="text-xl leading-none" /></span>
      <span id="menu-icon-close" class="hidden"><TablerIcon name="x" class="text-xl leading-none" /></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden border-t border-border bg-background px-4 pb-6 pt-3 lg:hidden">
    <nav class="flex flex-col gap-0.5" aria-label="Navigation mobile">
      {nav.map(({ label, href }) => (
        <a
          href={href}
          class:list={[
            'rounded-xl px-4 py-3 text-[0.95rem] font-medium transition-colors',
            isActive(href)
              ? 'bg-primary/10 text-primary font-semibold'
              : 'text-foreground/70 hover:bg-muted hover:text-foreground',
          ]}
        >
          {label}
        </a>
      ))}
    </nav>

    <div class="mt-4 flex flex-col gap-3 border-t border-border pt-4">
      <a
        href={`tel:${client.phoneForTel}`}
        class="flex items-center justify-center gap-2 rounded-full border border-border py-3 text-[0.95rem] font-semibold text-foreground transition-colors hover:border-primary/40 hover:text-primary"
      >
        <TablerIcon name="phone" class="text-base leading-none text-primary" />
        {client.phoneFormatted}
      </a>
      <a
        href="/devis"
        class="flex items-center justify-center gap-2 rounded-full bg-primary py-3 text-[0.95rem] font-bold text-primary-foreground shadow-sm transition-opacity hover:opacity-90"
      >
        Devis gratuit
        <TablerIcon name="arrow-right" class="text-sm leading-none" />
      </a>
    </div>
  </div>
</header>

<script>
  (() => {
    let menuOpen = false;

    const isDesktop = () => window.matchMedia('(min-width: 1024px)').matches;

    const getEls = () => ({
      btn:       document.getElementById('menu-toggle') as HTMLButtonElement | null,
      menu:      document.getElementById('mobile-menu') as HTMLElement | null,
      iconOpen:  document.getElementById('menu-icon-open') as HTMLElement | null,
      iconClose: document.getElementById('menu-icon-close') as HTMLElement | null,
    });

    const setOpen = (next: boolean) => {
      const { btn, menu, iconOpen, iconClose } = getEls();
      if (!btn || !menu) return;
      menuOpen = isDesktop() ? false : next;
      btn.setAttribute('aria-expanded', String(menuOpen));
      menu.classList.toggle('hidden', !menuOpen);
      iconOpen?.classList.toggle('hidden', menuOpen);
      iconClose?.classList.toggle('hidden', !menuOpen);
    };

    const syncLinks = () => {
      const { menu } = getEls();
      if (!menu) return;
      const path = window.location.pathname;
      menu.querySelectorAll<HTMLAnchorElement>('nav a').forEach((link) => {
        let href = link.getAttribute('href') || '';
        try { href = new URL(href, location.origin).pathname; } catch {}
        const active = href === path || (href !== '/' && path.startsWith(href));
        link.classList.toggle('bg-primary/10', active);
        link.classList.toggle('text-primary', active);
        link.classList.toggle('font-semibold', active);
        link.classList.toggle('text-foreground/70', !active);
        active ? link.setAttribute('aria-current', 'page') : link.removeAttribute('aria-current');
      });
    };

    // Single click handler on document — no per-init listener accumulation
    document.addEventListener('click', (e) => {
      const target = e.target as Element;
      if (target.closest('#menu-toggle')) {
        setOpen(!menuOpen);
      } else if (menuOpen && !target.closest('#mobile-menu')) {
        setOpen(false);
      } else if (menuOpen && target.closest('#mobile-menu a[href]')) {
        setOpen(false);
      }
    });

    window.addEventListener('resize', () => { if (isDesktop()) setOpen(false); }, { passive: true });
    document.addEventListener('astro:before-preparation', () => setOpen(false));
    document.addEventListener('astro:after-swap', () => { setOpen(false); syncLinks(); });

    setOpen(false);
    syncLinks();
  })();
</script>
