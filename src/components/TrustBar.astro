---
import TablerIcon from './TablerIcon.astro';

interface TrustItem {
  icon: 'star-filled' | 'check' | 'truck-delivery' | 'shield-check' | 'clock';
  label: string;
  value?: string;
}

interface Props {
  items?: TrustItem[];
}

const { items = [
  { icon: 'star-filled',    value: '5,0/5',      label: 'sur Google' },
  { icon: 'check',          value: '194',        label: 'avis vérifiés' },
  { icon: 'truck-delivery', value: '1 500+',     label: 'déménagements' },
  { icon: 'shield-check',   value: 'Depuis 2015', label: "11 ans d'expérience" },
  { icon: 'clock',          value: '100+',       label: 'professionnels' },
] } = Astro.props;
---

<div class="border-y border-border bg-card" aria-label="Indicateurs de confiance">
  <div class="mx-auto max-w-site overflow-x-auto px-4 py-5 sm:px-6">
    <ul class="flex flex-wrap items-center justify-around gap-x-8 gap-y-4 lg:justify-center lg:gap-x-16" role="list">
      {items.map(({ icon, label, value }) => (
        <li class="flex shrink-0 items-center gap-3">
          <span class="flex size-10 items-center justify-center rounded-full bg-primary/10 text-primary">
            <TablerIcon name={icon} filled class="text-lg leading-none" />
          </span>
          <span class="font-heading text-sm font-semibold text-foreground sm:text-base">
            {value && <span class="text-primary">{value} </span>}
            {label}
          </span>
        </li>
      ))}
    </ul>
  </div>
</div>
