---
import TablerIcon from './TablerIcon.astro';

interface Props {
  title: string;
}

const labels: Record<string, string> = {
  about:   'À propos',
  services:'Services',
  reviews: 'Avis',
  contact: 'Contact',
  success: 'Confirmation',
  blog:    'Blog',
  conseils:'Conseils',
  'demenagement-montpellier': 'Déménagement à Montpellier',
};

const { title } = Astro.props;

const segments = Astro.url.pathname
  .split('/')
  .filter(Boolean)
  .map((seg, i, arr) => ({
    label: labels[seg] ?? seg.replace(/-/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase()),
    href: '/' + arr.slice(0, i + 1).join('/'),
    isLast: i === arr.length - 1,
  }));
---

<section class="relative overflow-hidden bg-primary py-14 sm:py-16 lg:py-20">
  <!-- Glow -->
  <div
    class="pointer-events-none absolute -right-20 -top-20 size-72 rounded-full bg-primary-foreground/10 blur-3xl"
    aria-hidden="true"
  ></div>

  <div class="relative mx-auto max-w-site px-4 sm:px-6">
    <nav aria-label="Fil d'Ariane" class="mb-4">
      <ol class="flex flex-wrap items-center gap-1.5 text-sm text-primary-foreground/50">
        <li>
          <a href="/" class="transition-colors hover:text-primary-foreground">Accueil</a>
        </li>
        {segments.map(({ label, href, isLast }) => (
          <li class="flex items-center gap-1.5">
            <TablerIcon name="chevron-right" class="text-sm leading-none" />
            {isLast ? (
              <span aria-current="page" class="text-primary-foreground">{label}</span>
            ) : (
              <a href={href} class="transition-colors hover:text-primary-foreground">{label}</a>
            )}
          </li>
        ))}
      </ol>
    </nav>

    <h1 class="font-heading text-h1 font-bold uppercase text-primary-foreground">
      {title}
    </h1>

    <!-- Underline -->
    <div class="mt-4 h-1 w-16 rounded-full bg-primary-foreground/40"></div>
  </div>
</section>
