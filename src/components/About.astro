---
import TablerIcon from './TablerIcon.astro';

interface Props {
  topper?: string;
  heading?: string;
  body?: string[];
  benefits?: string[];
  ctaLabel?: string;
  ctaHref?: string;
  imageSrc?: string;
  imageAlt?: string;
}

const {
  topper   = 'Simple & rapide',
  heading  = "4 étapes. C'est tout.",
  body = [
    "Vous nous appelez ou vous remplissez le formulaire. En quelques minutes, nous cadrons le volume, l'adresse de départ, l'arrivée et les contraintes d'accès.",
    "Ensuite nous vous transmettons un devis fixe, nous planifions l'intervention et notre équipe prend en charge la protection, le transport et la remise en place.",
  ],
  benefits = [
    'Vous nous appelez: 5 minutes pour cerner le besoin.',
    'Devis gratuit & fixe: poste par poste, sans surprise.',
    'On gère tout: emballage, démontage, transport, remontage.',
    'Vous êtes chez vous: tout est remis en place et vérifié avec vous.',
  ],
  ctaLabel = 'Demander mon devis',
  ctaHref  = '/devis',
  imageSrc = '/hero_image.webp',
  imageAlt = 'Garde-meubles sécurisé AC Coursing',
} = Astro.props;
---

<section id="processus" class="bg-dark py-section">
  <div class="mx-auto grid max-w-site grid-cols-1 items-center gap-10 px-4 sm:px-6 lg:grid-cols-2 lg:gap-14">

    <!-- Image -->
    <div class="relative overflow-hidden rounded-xl border border-primary-fg/15 bg-dark-surface shadow-lg">
      <img
        src={imageSrc}
        alt={imageAlt}
        loading="lazy"
        decoding="async"
        class="size-full object-cover"
      />
      <!-- Primary strip at bottom -->
      <!-- <div class="absolute bottom-0 inset-x-0 h-1 bg-primary"></div> -->
    </div>

    <!-- Content -->
    <div class="space-y-5">
      <div class="inline-flex items-center gap-2 rounded-full border border-primary/30 bg-primary/10 px-4 py-1.5">
        <span class="size-2 rounded-full bg-primary"></span>
        <span class="text-topper font-bold uppercase tracking-widest text-primary">{topper}</span>
      </div>

      <h2 class="font-heading text-h2 font-bold uppercase text-primary-fg">{heading}</h2>

      {body.map((paragraph) => (
        <p class="leading-relaxed text-primary-fg/60">{paragraph}</p>
      ))}

      <ul class="space-y-3 pt-1" role="list">
        {benefits.map((benefit) => (
          <li class="flex items-start gap-3">
            <span class="mt-0.5 flex size-6 shrink-0 items-center justify-center rounded-full bg-primary/20 text-primary">
              <TablerIcon name="check" class="text-sm leading-none" />
            </span>
            <span class="text-primary-fg/80">{benefit}</span>
          </li>
        ))}
      </ul>

      <div class="pt-2">
        <a
          href={ctaHref}
          class="inline-flex min-h-[48px] items-center gap-2 rounded-md bg-primary px-7 py-3 text-base font-bold text-primary-foreground shadow-md transition-all hover:opacity-90 hover:shadow-lg focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
        >
          {ctaLabel}
          <TablerIcon name="arrow-right" class="text-base leading-none" />
        </a>
      </div>
    </div>

  </div>
</section>
