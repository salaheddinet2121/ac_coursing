---
import { brand } from '../config/brand';
import TablerIcon from './TablerIcon.astro';

interface Props {
  topper?: string;
  heading?: string;
  description?: string;
  ctaLabel?: string;
  ctaHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
  imageSrc?: string;
  imageAlt?: string;
}

const {
  topper         = 'Déménagement à Montpellier',
  heading        = brand.tagline,
  description    = '1 500+ déménagements réussis. Devis gratuit sous 24h. Assurance transport incluse. Prix fixe garanti.',
  ctaLabel       = 'Estimer le coût gratuitement',
  ctaHref        = '/devis',
  secondaryLabel = 'Voir les services',
  secondaryHref  = '/#services',
  imageSrc       = '/hero_image.webp',
  imageAlt       = 'Déménagement AC Coursing Montpellier',
} = Astro.props;

---

<section id="accueil" class="relative overflow-hidden bg-background py-10 sm:py-16 lg:py-24">

  <div class="relative mx-auto grid max-w-site grid-cols-1 items-center gap-8 px-4 sm:px-6 lg:grid-cols-[1.1fr_0.9fr] lg:gap-16">

    <!-- Content -->
    <div class="order-1 space-y-5 lg:space-y-6">

      <!-- Topper -->
      <div class="inline-flex items-center gap-2 rounded-full border border-primary/30 bg-primary/8 px-4 py-1.5">
        <span class="size-2 rounded-full bg-primary" aria-hidden="true"></span>
        <span class="text-topper font-bold uppercase tracking-widest text-primary">{topper}</span>
      </div>

      <!-- Heading -->
      <h1 class="font-heading text-display font-bold uppercase leading-none text-foreground" transition:name="hero-heading">
        {heading}
      </h1>

      <!-- Description -->
      <p class="max-w-xl text-lead leading-relaxed text-muted-foreground">
        {description}
      </p>

      <!-- CTAs -->
      <div class="flex flex-col gap-3 pt-1 sm:flex-row sm:items-center sm:gap-4">
        <a
          href={ctaHref}
          class="inline-flex min-h-[48px] items-center justify-center rounded-md bg-primary px-7 py-3 text-base font-bold text-primary-foreground transition-opacity hover:opacity-90 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
        >
          {ctaLabel}
        </a>
        <a
          href={secondaryHref}
          class="inline-flex min-h-[48px] items-center justify-center gap-2 rounded-md border-2 border-primary px-7 py-3 text-base font-bold text-primary transition-colors hover:bg-primary hover:text-primary-foreground focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
        >
          {secondaryLabel}
          <TablerIcon name="arrow-right" class="text-base leading-none" />
        </a>
      </div>

    </div>

    <!-- Image — hidden on mobile, visible from lg -->
    <div class="relative hidden lg:block lg:order-2" transition:name="hero-image">

      <!-- Frame decoration -->
      <div class="absolute -right-3 -top-3 h-full w-full rounded-xl border-2 border-primary/20" aria-hidden="true"></div>

      <!-- Badge -->
      <div class="absolute -bottom-4 -left-4 z-10 flex items-center gap-3 rounded-xl border border-border bg-background px-4 py-3 shadow-lg">
        <span class="flex size-10 shrink-0 items-center justify-center rounded-lg bg-primary text-primary-foreground">
          <TablerIcon name="shield-check" filled class="text-lg leading-none" />
        </span>
        <div>
          <p class="text-xs font-bold uppercase tracking-wide text-foreground">Assuré & garanti</p>
          <p class="text-xs text-muted-foreground">Prix fixe · transport inclus</p>
        </div>
      </div>

      <!-- Image -->
      <div class="relative overflow-hidden rounded-xl border border-border bg-card shadow-xl aspect-[4/3]">
        <img
          src={imageSrc}
          alt={imageAlt}
          loading="lazy"
          decoding="async"
          class="size-full object-cover"
        />
      </div>
    </div>

  </div>
</section>
